{
  "name": "eodhd-openapi-spec",
  "version": "2.0.0",
  "description": "OpenAPI 3.1.0 specification for EODHD Financial Data API",
  "main": "openapi.yaml",
  "scripts": {
    "validate": "redocly lint openapi.yaml",
    "preview": "redocly preview-docs openapi.yaml",
    "build": "redocly bundle openapi.yaml -o dist/openapi.yaml",
    "generate-python": "openapi-generator-cli generate -i openapi.yaml -g python -o ./clients/python",
    "generate-typescript": "openapi-generator-cli generate -i openapi.yaml -g typescript-axios -o ./clients/typescript",
    "generate-java": "openapi-generator-cli generate -i openapi.yaml -g java -o ./clients/java",
    "generate-go": "openapi-generator-cli generate -i openapi.yaml -g go -o ./clients/go"
  },
  "keywords": [
    "openapi",
    "swagger",
    "api",
    "financial-data",
    "eodhd",
    "stocks",
    "market-data",
    "trading",
    "finance",
    "rest-api"
  ],
  "author": "Alex Chernyshev",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/EodHistoricalData/EODHD-openapi.git"
  },
  "bugs": {
    "url": "https://github.com/EodHistoricalData/EODHD-openapi/issues"
  },
  "homepage": "https://github.com/EodHistoricalData/EODHD-openapi#readme",
  "devDependencies": {
    "@redocly/cli": "^1.10.0",
    "@openapitools/openapi-generator-cli": "^2.9.0"
  }
}
